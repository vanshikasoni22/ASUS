# Set default behaviour to automatically normalise line endings.
* text=auto

# Explicitly declare text files to ensure proper line endings.
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf

# Binary files — do not modify.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.mp4  binary
*.webp binary
